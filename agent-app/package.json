{
  "name": "agent-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite --config vite.config.web.ts",
    "build:web": "vite build --config vite.config.web.ts",
    "build": "pnpm build:web && wrangler deploy",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p . && tsc --noEmit -p tsconfig.web.json",
    "d1:migrate:local": "wrangler d1 migrations apply sidebar --local",
    "d1:migrate:remote": "wrangler d1 migrations apply sidebar --remote"
  },
  "dependencies": {
    "@tanstack/ai": "^0.28.0",
    "@tanstack/ai-code-mode": "^0.2.5",
    "@tanstack/ai-isolate-cloudflare": "^0.2.21",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "agents": "^0.14.5",
    "hono": "^4.12.25",
    "hono-agents": "^3.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sucrase": "^3.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.7",
    "wrangler": "^4.0.0"
  }
}
