{
  "name": "brave-extension",
  "displayName": "Brave Dev Extension",
  "version": "0.1.0",
  "description": "Brave sidebar extension connected to local CLI tools — Claude Code, Gemini, Copilot, Codex — with page inspection and scraping.",
  "author": "aloe",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "postinstall": "bash scripts/scrub-native-xattrs.sh && node scripts/scrub-quarantine.mjs",
    "dev": "node scripts/build-extension.mjs --watch",
    "build": "node scripts/build-extension.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "package": "node scripts/build-extension.mjs && node scripts/package-extension.mjs",
    "install-host": "node scripts/install-native-host.mjs",
    "uninstall-host": "node scripts/uninstall-native-host.mjs",
    "diagnose-host": "node scripts/diagnose-native-host.mjs",
    "scrub-native": "bash scripts/scrub-native-xattrs.sh && node scripts/scrub-quarantine.mjs",
    "rebuild-pty": "pnpm --dir native-host rebuild node-pty --config.build-from-source=true && bash scripts/scrub-native-xattrs.sh && node scripts/scrub-quarantine.mjs && node scripts/warm-node-pty.mjs && sleep 1 && bash scripts/scrub-native-xattrs.sh",
    "warm-pty": "node scripts/warm-node-pty.mjs && sleep 1 && bash scripts/scrub-native-xattrs.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p .",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@mozilla/readability": "^0.6.0",
    "@tanstack/react-virtual": "^3.14.6",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^24",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "happy-dom": "^20.11.0",
    "postcss": "^8.5.20",
    "prettier": "3.9.5",
    "tailwindcss": "^3.4.19",
    "typescript": "6.0.3",
    "vite": "npm:rolldown-vite@7.3.1",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "@babel/traverse": "7.29.0",
      "content-security-policy-parser": "0.6.0",
      "msgpackr": "1.11.9",
      "svelte": "5.55.9"
    }
  },
  "manifest": {
    "permissions": [
      "storage",
      "unlimitedStorage",
      "tabs",
      "activeTab",
      "sidePanel",
      "nativeMessaging",
      "debugger",
      "scripting",
      "contextMenus",
      "tabCapture",
      "desktopCapture",
      "offscreen",
      "alarms",
      "management",
      "bookmarks",
      "history",
      "cookies",
      "downloads",
      "tabGroups",
      "browsingData",
      "webNavigation",
      "declarativeNetRequest",
      "declarativeNetRequestWithHostAccess",
      "privacy",
      "contentSettings"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "chrome_url_overrides": {
      "newtab": "newtab.html"
    },
    "commands": {
      "save-link": {
        "suggested_key": {
          "default": "Ctrl+Shift+H",
          "mac": "Ctrl+Shift+H"
        },
        "description": "Save selected text as a highlight, or save the current page link"
      },
      "screenshot-page": {
        "suggested_key": {
          "default": "Ctrl+Shift+S",
          "mac": "Ctrl+Shift+S"
        },
        "description": "Take and download a screenshot of the current tab"
      },
      "reload-extension": {
        "suggested_key": {
          "default": "Ctrl+Shift+E",
          "mac": "Ctrl+Shift+E"
        },
        "description": "Reload the extension"
      },
      "speak-selection": {
        "suggested_key": {
          "default": "Alt+S",
          "mac": "Alt+S"
        },
        "description": "Speak the selected text"
      }
    }
  }
}
